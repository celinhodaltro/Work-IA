@page "/activity"
@using MudBlazor

<MudText Typo="Typo.h4">Activity Feed</MudText>
<MudText Class="mb-6">Real-time agent and workspace events</MudText>

<MudPaper Class="pa-4">
    @foreach (var item in Activities)
    {
        <MudAlert Severity="@item.Severity" Class="mb-2">
            <MudText><strong>@item.Agent:</strong> @item.Message <small>@item.Time</small></MudText>
        </MudAlert>
    }
</MudPaper>

@code {
    private List<ActivityItem> Activities = new()
    {
        new("Head of Engineering", "Sprint completed", Severity.Success, "5m ago"),
        new("Tech Lead Backend", "Domain models implemented", Severity.Normal, "10m ago"),
        new("Test Lead", "Test suite: 42/45 passed", Severity.Warning, "15m ago"),
        new("Chief Reviewer", "Code review requested", Severity.Info, "20m ago"),
    };

    private record ActivityItem(string Agent, string Message, Severity Severity, string Time);
}
