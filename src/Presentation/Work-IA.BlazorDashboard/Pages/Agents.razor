@page "/agents"
@using MudBlazor

<MudText Typo="Typo.h4">Agent Workforce</MudText>
<MudText Class="mb-6" Typo="Typo.body2">AI Office OS organizational chart</MudText>

<MudGrid>
    @foreach (var agent in AgentItems)
    {
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="d-flex flex-column pa-4 agent-card" Style="height: 200px">
                <MudCardContent>
                    <div class="d-flex align-center mb-2">
                        <MudAvatar Color="@GetColorForRole(agent.Role)" Size="Size.Large">
                            @agent.Initial
                        </MudAvatar>
                        <div class="ml-4">
                            <MudText Typo="Typo.h6">@agent.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@agent.Role</MudText>
                        </div>
                    </div>
                    <div class="d-flex align-center mt-4">
                        <span class="agent-status-dot @agent.Status.ToLowerInvariant()"></span>
                        <MudChip Size="Size.Small" Color="@GetStatusColor(agent.Status)">
                            @agent.Status
                        </MudChip>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<AgentInfo> AgentItems = new()
    {
        new("Head of Engineering", "H", "Head Of Engineering", "Running"),
        new("Tech Lead Backend", "B", "Tech Lead Backend", "Running"),
        new("Tech Lead Frontend", "F", "Tech Lead Frontend", "Running"),
        new("Tech Lead Game", "G", "Tech Lead Game", "Paused"),
        new("Tech Lead DevOps", "D", "Tech Lead DevOps", "Running"),
        new("Test Lead", "T", "Test Lead", "Running"),
        new("Chief Reviewer", "R", "Chief Reviewer", "Running"),
        new("Audit Lead", "A", "Audit Lead", "Running"),
        new("Architect", "A", "Architect", "Running"),
    };

    private Color GetColorForRole(string role) => role switch
    {
        "Head Of Engineering" => Color.Primary,
        "Tech Lead Backend" => Color.Success,
        "Tech Lead Frontend" => Color.Secondary,
        "Tech Lead Game" => Color.Warning,
        "Tech Lead DevOps" => Color.Info,
        "Test Lead" => Color.Error,
        _ => Color.Default
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Running" => Color.Success,
        "Paused" => Color.Warning,
        "Stopped" => Color.Error,
        _ => Color.Default
    };

    private record AgentInfo(string Name, string Initial, string Role, string Status);
}
