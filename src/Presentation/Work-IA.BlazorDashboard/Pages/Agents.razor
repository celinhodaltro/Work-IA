@page "/agents"
@using MudBlazor

<MudText Typo="Typo.h4">Agent Workforce</MudText>
<MudText Class="mb-6">All AI Office OS agents and their status</MudText>

<MudGrid>
    @foreach (var agent in AgentItems)
    {
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="pa-4">
                <MudCardContent>
                    <MudAvatar Class="mb-2" Color="@GetColorForRole(agent.Role)">@agent.Initial</MudAvatar>
                    <MudText Typo="Typo.h6">@agent.Name</MudText>
                    <MudText Typo="Typo.body2">@agent.Role</MudText>
                    <MudChip Size="Size.Small" Color="@GetStatusColor(agent.Status)">@agent.Status</MudChip>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<AgentInfo> AgentItems = new()
    {
        new("Head of Engineering", "H", "Head Of Engineering", "Running"),
        new("Tech Lead Backend", "T", "Tech Lead Backend", "Running"),
        new("Tech Lead Frontend", "T", "Tech Lead Frontend", "Running"),
        new("Tech Lead Game", "T", "Tech Lead Game", "Paused"),
        new("Tech Lead DevOps", "T", "Tech Lead DevOps", "Running"),
        new("Test Lead", "T", "Test Lead", "Running"),
        new("Chief Reviewer", "C", "Chief Reviewer", "Running"),
        new("Audit Lead", "A", "Audit Lead", "Running"),
        new("Architect", "A", "Architect", "Running"),
    };

    private Color GetColorForRole(string role) => role switch
    {
        "Head Of Engineering" => Color.Primary,
        "Tech Lead Backend" => Color.Success,
        "Tech Lead Frontend" => Color.Secondary,
        "Tech Lead Game" => Color.Warning,
        "Tech Lead DevOps" => Color.Info,
        "Test Lead" => Color.Error,
        _ => Color.Default
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Running" => Color.Success,
        "Paused" => Color.Warning,
        _ => Color.Default
    };

    private record AgentInfo(string Name, string Initial, string Role, string Status);
}
