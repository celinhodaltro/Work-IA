@inherits LayoutComponentBase
@using MudBlazor
@using Work_IA.BlazorDashboard.Theme

<MudThemeProvider Theme="@AIOfficeTheme.Create()" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">AI Office OS</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Inherit" />
    </MudAppBar>
    <MudDrawer Open="@_drawerOpen" Variant="@DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigation</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/agents" Icon="@Icons.Material.Filled.Groups">Agents</MudNavLink>
            <MudNavLink Href="/activity" Icon="@Icons.Material.Filled.Timeline">Activity</MudNavLink>
            <MudNavLink Href="/contratar" Icon="@Icons.Material.Filled.PersonAdd">Contratar</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
