@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudDrawer Open="@_drawerOpen" Variant="@DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">AI Office OS</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/">Dashboard</MudNavLink>
            <MudNavLink Href="/agents">Agents</MudNavLink>
            <MudNavLink Href="/activity">Activity</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
}
